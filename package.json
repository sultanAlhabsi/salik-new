{
  "name": "salik",
  "version": "1.0.0",
  "description": "SALIK multi-tenant B2B distribution, orders, delivery, and invoicing platform.",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "npm run prisma:generate && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/src/server/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/domain tests/helpers tests/config",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/components --passWithNoTests",
    "test:contract": "vitest run tests/contracts --passWithNoTests",
    "test:smoke": "vitest run tests/smoke",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:regression": "playwright test",
    "test:e2e:a11y": "playwright test --grep @a11y --project=chromium-1440 --project=chromium-430 --project=chromium-320",
    "test:e2e:visual": "playwright test --grep @visual --project=chromium-1440 --project=chromium-430 --project=chromium-320",
    "test:e2e:ui:pr": "playwright test --grep \"@ui-smoke|@a11y|@visual\" --project=chromium-1440 --project=chromium-430 --project=chromium-320",
    "test:e2e:ui:matrix": "playwright test --grep @matrix",
    "test:regression": "npm run test:coverage && npm run test:e2e:regression",
    "quality": "npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "tsx prisma/apply-migrations.ts",
    "db:apply": "tsx prisma/apply-migrations.ts",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "b2b",
    "distribution",
    "multi-tenant",
    "oman",
    "saas"
  ],
  "author": "SALIK",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/server": "^1.4.0",
    "@supabase/supabase-js": "2.110.7",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "dotenv": "17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.25.0",
    "multer": "^2.2.0",
    "nanoid": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
